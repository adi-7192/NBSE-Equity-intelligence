# Supabase Postgres
# Use the Supavisor transaction pooler connection string from:
# Supabase Dashboard -> Connect -> ORMs / Transaction pooler
DATABASE_URL=postgres://[YOUR-DB-USER]:[YOUR-PASSWORD]@[YOUR-POOLER-HOST]:6543/postgres?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
APP_ENCRYPTION_KEY=replace-with-a-dedicated-encryption-secret

# One-time bootstrap admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-temp-password

# Live market relay
LIVE_RELAY_URL=http://localhost:4001
LIVE_RELAY_SECRET=replace-with-a-shared-relay-secret
LIVE_RELAY_PORT=4001

# Zerodha Kite relay credentials
# `KITE_ACCESS_TOKEN` is not a forever secret. Refresh it operationally each day before market open.
KITE_API_KEY=your-kite-api-key
KITE_ACCESS_TOKEN=your-fresh-kite-access-token

# Zerodha benchmark instrument tokens used by the relay and disconnected fallback contract
KITE_BENCHMARK_NIFTY50_TOKEN=
KITE_BENCHMARK_SENSEX_TOKEN=
KITE_BENCHMARK_NIFTY_BANK_TOKEN=
KITE_BENCHMARK_MIDCAP150_TOKEN=
